DJANGO_SECRET_KEY=dev-please-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,<appgw-fqdn>,<custom-domain>

# CORS: in development you can leave allow all = True, for prod set to False and list origins
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://<appgw-fqdn>


# Azure SQL. Leave DB_HOST empty for local SQLite development.
DB_HOST=
DB_PORT=1433
DB_NAME=appdb-group4f-dev
DB_USER=sqladminuser
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_EXTRA_PARAMS=Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;
# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Timezone
DJANGO_TIME_ZONE=UTC

# Celery/Redis (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# AI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_VISION_MODEL=
# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=
DJANGO_LOG_LEVEL=INFO
GOOGLE_OAUTH_CLIENT_ID=
