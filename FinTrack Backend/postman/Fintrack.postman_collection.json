{
  "info": {
    "name": "Fintrack API",
    "_postman_id": "e6d1a3c2-4f9e-47c1-9f7a-9b8e4a1b0c21",
    "description": "Postman collection for Fintrack (Django + DRF + JWT). Import with the Fintrack.local environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (random user)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/accounts/register/", "host": ["{{baseUrl}}"], "path": ["api","accounts","register",""] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user{{$timestamp}}@example.com\",\n  \"password\": \"Test1234!\",\n  \"username\": \"user{{$timestamp}}\",\n  \"name\": \"{{$randomFullName}}\"\n}" }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const b = JSON.parse(pm.request.body.raw);",
                  "  pm.environment.set('username', b.username);",
                  "  pm.environment.set('password', b.password);",
                  "  pm.environment.set('email', b.email);",
                  "} catch(e) {}",
                  "pm.test('Register returns 201/200/400', () => pm.expect([200,201,400]).to.include(pm.response.code));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Token: Obtain",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/token/", "host": ["{{baseUrl}}"], "path": ["api","auth","token",""] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}" }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) pm.environment.set('accessToken', data.access);",
                  "if (data.refresh) pm.environment.set('refreshToken', data.refresh);",
                  "pm.test('Got access token', () => pm.expect(data).to.have.property('access'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Token: Verify",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/token/verify/", "host": ["{{baseUrl}}"], "path": ["api","auth","token","verify",""] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{accessToken}}\"\n}" }
          },
          "response": []
        },
        {
          "name": "Token: Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/token/refresh/", "host": ["{{baseUrl}}"], "path": ["api","auth","token","refresh",""] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}" }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) pm.environment.set('accessToken', data.access);",
                  "pm.test('Refreshed access token', () => pm.expect(data).to.have.property('access'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout (Blacklist Refresh)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/accounts/logout/", "host": ["{{baseUrl}}"], "path": ["api","accounts","logout",""] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}" }
          },
          "response": []
        }
      ]
    },
