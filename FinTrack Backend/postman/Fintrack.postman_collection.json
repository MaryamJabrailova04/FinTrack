  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const now = new Date();",
          "pm.environment.set('today', now.toISOString().slice(0,10));",
          "pm.environment.set('isoNow', now.toISOString());",
          "pm.environment.set('year', String(now.getUTCFullYear()));",
          "pm.environment.set('month', String(now.getUTCMonth()+1));"
        ],
        "type": "text/javascript"
      }
    }
  ]
